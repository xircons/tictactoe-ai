# Frontend env vars (Vite — must be prefixed with VITE_)
# Copy to .env.local for development; configure in Vercel dashboard for production.

# Backend API URL (the Render service URL after deploy)
VITE_API_PRODUCTION_URL=https://tictactoe-ai-api.onrender.com

# Local dev override (optional — defaults to http://localhost:5001 when DEV is true)
VITE_API_LOCAL_URL=http://localhost:5001

# Vite base path. Leave unset (or '/') for Vercel.
# Set to '/tictactoe-ai/' only if deploying back to GitHub Pages.
# VITE_BASE=/
